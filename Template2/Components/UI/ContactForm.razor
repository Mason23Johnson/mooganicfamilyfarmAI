@rendermode InteractiveServer

<EditForm Model="_model" OnValidSubmit="Submit" class="contact-form">
    <DataAnnotationsValidator />
    <div class="form-grid">
        <label>
            <span>Name</span>
            <InputText @bind-Value="_model.Name" placeholder="Jane Smith" />
            <ValidationMessage For="@(() => _model.Name)" />
        </label>
        <label>
            <span>Email</span>
            <InputText @bind-Value="_model.Email" type="email" placeholder="jane@company.com" />
            <ValidationMessage For="@(() => _model.Email)" />
        </label>
    </div>
    <label>
        <span>Company</span>
        <InputText @bind-Value="_model.Company" placeholder="Company name" />
    </label>
    <label>
        <span>Project Type</span>
        <InputSelect @bind-Value="_model.ProjectType">
            <option>Website Launch</option>
            <option>Rebrand</option>
            <option>Product Marketing</option>
            <option>Custom Blazor App</option>
        </InputSelect>
    </label>
    <label>
        <span>What are you building?</span>
        <InputTextArea @bind-Value="_model.Message" placeholder="Tell us about your goals, audience, timeline, and must-have sections." />
        <ValidationMessage For="@(() => _model.Message)" />
    </label>
    <button class="btn btn-primary btn-wide" type="submit">Send Message</button>
    @if (_submitted)
    {
        <p class="form-success">Thanks, @_model.Name. This demo form is ready to connect to your email, CRM, or API.</p>
    }
</EditForm>

@code {
    private readonly ContactRequest _model = new();
    private bool _submitted;

    private void Submit() => _submitted = true;

    private sealed class ContactRequest
    {
        [System.ComponentModel.DataAnnotations.Required]
        public string Name { get; set; } = "";

        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.EmailAddress]
        public string Email { get; set; } = "";

        public string Company { get; set; } = "";
        public string ProjectType { get; set; } = "Website Launch";

        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.MinLength(20)]
        public string Message { get; set; } = "";
    }
}
