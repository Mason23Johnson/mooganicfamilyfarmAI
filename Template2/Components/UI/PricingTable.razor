@rendermode InteractiveServer
@inject SiteConfig Config

<section class="section pricing-section">
    <div class="container">
        <SectionHeader Eyebrow="Pricing" Title="Plans That Fit The Stage You Are In" Description="Use these cards for retainers, product tiers, memberships, packages, or consultation levels." />

        @if (Config.ShowPricingToggle)
        {
            <div class="billing-toggle reveal" role="group" aria-label="Billing frequency">
                <button class="@ToggleClass(false)" @onclick="() => _annual = false">Monthly</button>
                <button class="@ToggleClass(true)" @onclick="() => _annual = true">Annual <span>Save 20%</span></button>
            </div>
        }

        <div class="pricing-grid">
            @foreach (var tier in Config.PricingTiers)
            {
                <article class="pricing-card reveal @(tier.IsPopular ? "popular" : "")">
                    @if (tier.IsPopular)
                    {
                        <span class="popular-badge">Most Popular</span>
                    }
                    <h3>@tier.Name</h3>
                    <p>@tier.Description</p>
                    <div class="price">
                        <span>@(_annual ? tier.AnnualPrice : tier.MonthlyPrice)</span>
                        @if (tier.MonthlyPrice != "Custom")
                        {
                            <small>/mo</small>
                        }
                    </div>
                    <a class="btn @(tier.IsPopular ? "btn-primary" : "btn-ghost") btn-wide" href="@tier.CtaUrl">Choose @tier.Name</a>
                    <ul>
                        @foreach (var item in tier.Features)
                        {
                            <li>@item</li>
                        }
                    </ul>
                </article>
            }
        </div>
    </div>
</section>

@code {
    private bool _annual = true;
    private string ToggleClass(bool annual) => _annual == annual ? "active" : "";
}
