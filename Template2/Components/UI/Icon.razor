@switch (Name)
{
    case "target":
        <svg class="@CssClass" viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="8" /><circle cx="12" cy="12" r="3" /><path d="M12 2v3M22 12h-3M12 22v-3M2 12h3" /></svg>
        break;
    case "palette":
        <svg class="@CssClass" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3a9 9 0 0 0 0 18h1.5a2 2 0 0 0 1.3-3.5 1.5 1.5 0 0 1 1-2.6H17a4 4 0 0 0 4-4C21 6.5 17 3 12 3Z" /><circle cx="7.5" cy="10.5" r="1" /><circle cx="10.5" cy="7.5" r="1" /><circle cx="14.5" cy="7.8" r="1" /><circle cx="16.5" cy="11" r="1" /></svg>
        break;
    case "code":
        <svg class="@CssClass" viewBox="0 0 24 24" aria-hidden="true"><path d="m8 9-4 3 4 3M16 9l4 3-4 3M14 4l-4 16" /></svg>
        break;
    case "chart":
        <svg class="@CssClass" viewBox="0 0 24 24" aria-hidden="true"><path d="M4 19V5M4 19h17" /><rect x="7" y="11" width="3" height="5" rx="1" /><rect x="12" y="7" width="3" height="9" rx="1" /><rect x="17" y="4" width="3" height="12" rx="1" /></svg>
        break;
    case "rocket":
        <svg class="@CssClass" viewBox="0 0 24 24" aria-hidden="true"><path d="M14 4c3.5.4 5.6 2.5 6 6l-5 5-6-6 5-5Z" /><path d="m9 15-4 4 1.5-5.5L4 11l5.5-1.5" /><circle cx="15" cy="9" r="1.5" /></svg>
        break;
    case "chat":
        <svg class="@CssClass" viewBox="0 0 24 24" aria-hidden="true"><path d="M4 5h16v11H8l-4 4V5Z" /><path d="M8 9h8M8 13h5" /></svg>
        break;
    case "spark":
        <svg class="@CssClass" viewBox="0 0 24 24" aria-hidden="true"><path d="m12 2 2.4 6.8L21 12l-6.6 3.2L12 22l-2.4-6.8L3 12l6.6-3.2L12 2Z" /></svg>
        break;
    case "sliders":
        <svg class="@CssClass" viewBox="0 0 24 24" aria-hidden="true"><path d="M4 7h9M17 7h3M4 17h3M11 17h9" /><circle cx="15" cy="7" r="2" /><circle cx="9" cy="17" r="2" /></svg>
        break;
    case "bolt":
        <svg class="@CssClass" viewBox="0 0 24 24" aria-hidden="true"><path d="M13 2 4 14h7l-1 8 10-13h-7l0-7Z" /></svg>
        break;
    case "grid":
        <svg class="@CssClass" viewBox="0 0 24 24" aria-hidden="true"><rect x="4" y="4" width="7" height="7" rx="1" /><rect x="13" y="4" width="7" height="7" rx="1" /><rect x="4" y="13" width="7" height="7" rx="1" /><rect x="13" y="13" width="7" height="7" rx="1" /></svg>
        break;
    default:
        <svg class="@CssClass" viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="8" /><path d="m9 12 2 2 4-5" /></svg>
        break;
}

@code {
    [Parameter] public string Name { get; set; } = "check";
    [Parameter] public string CssClass { get; set; } = "icon";
}
