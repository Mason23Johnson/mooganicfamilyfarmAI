@page "/services"
@inject SiteConfig Config

<PageTitle>Services - @Config.SiteName</PageTitle>

<section class="page-hero">
    <div class="container narrow reveal">
        <span class="eyebrow">Services</span>
        <h1>Offer Cards Ready For Many Types Of Business</h1>
        <p>Swap these labels for treatments, menu packages, software modules, consulting offers, retail services, or professional specialties.</p>
    </div>
</section>

<section class="section">
    <div class="container service-grid">
        @foreach (var service in Config.Services)
        {
            <article class="service-card reveal">
                <Icon Name="@service.Icon" />
                <h3>@service.Title</h3>
                <p>@service.Description</p>
                <ul>
                    @foreach (var detail in service.Details)
                    {
                        <li>@detail</li>
                    }
                </ul>
            </article>
        }
    </div>
</section>

<section class="section alt">
    <div class="container process-grid">
        <div>
            <span class="eyebrow">Process</span>
            <h2>Simple Enough To Explain, Flexible Enough To Sell</h2>
            <p>The process section works as onboarding, patient journey, buying process, implementation path, or event planning steps.</p>
        </div>
        <div class="steps">
            @foreach (var step in Config.Steps)
            {
                <article class="step-card reveal">
                    <span>@step.Number</span>
                    <div>
                        <h3>@step.Title</h3>
                        <p>@step.Description</p>
                    </div>
                </article>
            }
        </div>
    </div>
</section>
