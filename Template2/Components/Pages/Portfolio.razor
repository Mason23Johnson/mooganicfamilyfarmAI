@page "/portfolio"
@inject SiteConfig Config

<PageTitle>Portfolio - @Config.SiteName</PageTitle>

<section class="page-hero">
    <div class="container narrow reveal">
        <span class="eyebrow">Portfolio</span>
        <h1>Case Studies, Collections, Projects, And Featured Work</h1>
        <p>Show proof with industry labels, result statements, and flexible tags.</p>
    </div>
</section>

<section class="section">
    <div class="container portfolio-grid">
        @foreach (var item in Config.PortfolioItems)
        {
            <article class="portfolio-card reveal">
                <span>@item.Industry</span>
                <h3>@item.Title</h3>
                <p>@item.Result</p>
                <div class="tag-row">
                    @foreach (var tag in item.Tags)
                    {
                        <small>@tag</small>
                    }
                </div>
            </article>
        }
    </div>
</section>
