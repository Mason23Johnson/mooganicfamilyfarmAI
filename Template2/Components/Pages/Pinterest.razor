@page "/pinterest"
@inject SiteConfig Config

<PageTitle>Pinterest - @Config.SiteName</PageTitle>

<section class="page-hero">
    <div class="container narrow reveal">
        <span class="eyebrow">Pinterest</span>
        <h1>Our Pinterest Boards</h1>
        <p>We've been saving the best of the farm and kitchen for years. Browse our boards and find something to try this week.</p>
    </div>
</section>

<section class="section">
    <div class="container">
        <div class="pinterest-hero reveal" style="text-align:center; margin-bottom:48px;">
            <p style="font-size:1.1rem; max-width:600px; margin-inline:auto;">
                Follow us on Pinterest for daily recipes, garden inspiration, farm life photos, and all the little finds that make our homestead feel like home.
            </p>
            <a class="btn btn-primary" style="margin-top:24px;" href="@Config.PinterestUrl" target="_blank" rel="noopener">
                Follow Mooganic Family Farm on Pinterest
            </a>
        </div>

        <div class="pinterest-grid">
            @foreach (var board in Config.PinterestBoards)
            {
                <a class="pinterest-card reveal" href="@board.PinterestUrl" target="_blank" rel="noopener">
                    <div class="pinterest-card-img" style="background-image:url('@board.ImageUrl')"></div>
                    <div class="pinterest-card-body">
                        <h3>@board.Title</h3>
                        <p>@board.Description</p>
                        <span class="btn btn-ghost">Open Board</span>
                    </div>
                </a>
            }
        </div>
    </div>
</section>

<section class="section alt">
    <div class="container">
        <SectionHeader Eyebrow="Why Pinterest" Title="A Little Corner We Love" Description="Pinterest is where we save the things we actually go back to. It's honest and low-pressure and honestly one of our favorite ways to share." />
        <div class="stats-grid">
            <div class="stat-card reveal">
                <strong>4</strong>
                <span>Active Boards</span>
            </div>
            <div class="stat-card reveal">
                <strong>Recipes</strong>
                <span>Our Most Popular Board</span>
            </div>
            <div class="stat-card reveal">
                <strong>Daily</strong>
                <span>New Pins Added</span>
            </div>
            <div class="stat-card reveal">
                <strong>Free</strong>
                <span>Always & Forever</span>
            </div>
        </div>
    </div>
</section>

<section class="cta-section">
    <div class="container cta-card reveal">
        <span class="eyebrow">Stay Connected</span>
        <h2>Save Something Good Today</h2>
        <p>Head over to our Pinterest and save a recipe for tonight or a garden tip for spring. We'd love to see you there.</p>
        <a class="btn btn-light" href="@Config.PinterestUrl" target="_blank" rel="noopener">Visit Our Pinterest</a>
    </div>
</section>
