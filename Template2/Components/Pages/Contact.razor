@page "/contact"
@inject SiteConfig Config

<PageTitle>Contact - @Config.SiteName</PageTitle>

<section class="page-hero">
    <div class="container narrow reveal">
        <span class="eyebrow">Contact</span>
        <h1>Start The Conversation</h1>
        <p>Keep this as a lead form, booking intake, quote request, demo request, or consultation gateway.</p>
    </div>
</section>

<section class="section">
    <div class="container contact-grid">
        <div class="contact-panel reveal">
            <span class="eyebrow">Reach Us</span>
            <h2>Tell Us What You Are Building</h2>
            <p>Share your goals and we will point you toward the right site structure, theme, and next steps.</p>
            <div class="contact-methods">
                <a href="mailto:@Config.ContactEmail">@Config.ContactEmail</a>
                <a href="tel:@Config.ContactPhone">@Config.ContactPhone</a>
                <span>@Config.ContactAddress</span>
            </div>
        </div>
        <ContactForm />
    </div>
</section>
